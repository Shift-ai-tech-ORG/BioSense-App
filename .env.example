# ─── Database ────────────────────────────────────────────────────────────────
# Option A: local Docker (see docker-compose.yml — run `docker compose up -d`)
DATABASE_URL="postgresql://biosense:biosense@localhost:5432/biosense"
# Option B: Neon / Supabase free tier
# DATABASE_URL="postgresql://user:password@host:5432/biosense?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-your-secret"
NEXTAUTH_URL="http://localhost:3000"

# ─── Anthropic (Claude AI) ────────────────────────────────────────────────────
# https://console.anthropic.com
ANTHROPIC_API_KEY=""

# ─── Cloudflare R2 (PDF storage) ─────────────────────────────────────────────
# Leave blank to skip file uploads in local dev
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="biosense-pdfs"
R2_PUBLIC_URL=""

# ─── Stripe ───────────────────────────────────────────────────────────────────
# https://dashboard.stripe.com  — leave blank to skip billing in local dev
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_MONTHLY_PRICE_ID=""
STRIPE_ANNUAL_PRICE_ID=""

# ─── Resend (transactional email) ─────────────────────────────────────────────
# https://resend.com — leave blank to skip email in local dev
RESEND_API_KEY=""
EMAIL_FROM="BioSense <noreply@yourdomain.com>"

# ─── Wearable OAuth ───────────────────────────────────────────────────────────
# Leave blank — wearable connect buttons will show but OAuth won't complete
OURA_CLIENT_ID=""
OURA_CLIENT_SECRET=""

WHOOP_CLIENT_ID=""
WHOOP_CLIENT_SECRET=""

GARMIN_CONSUMER_KEY=""
GARMIN_CONSUMER_SECRET=""
